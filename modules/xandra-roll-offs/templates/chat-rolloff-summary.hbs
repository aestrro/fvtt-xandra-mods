<div class="xandra-roll-offs-chat xro-roll-off-summary">
  <h4>{{localize 'XANDRA_ROLL_OFFS.Labels.RollOffComplete'}}</h4>
  {{#if winner}}
  <h2 class="xro-winner">{{localize 'XANDRA_ROLL_OFFS.Chat.RollOffWinner' name=winner}}</h2>
  {{/if}}
  {{#if rounds.length}}
  <ul class="xro-round-list">
    {{#each rounds}}
    <li>{{localize 'XANDRA_ROLL_OFFS.Labels.Round' round=round}} — {{localize 'XANDRA_ROLL_OFFS.Chat.RoundWinner' name=winnerName}}</li>
    {{/each}}
  </ul>
  {{/if}}
  {{#if tallies.length}}
  <h5>{{localize 'XANDRA_ROLL_OFFS.Labels.Leaderboard'}}</h5>
  <ol class="xro-leaderboard">
    {{#each tallies}}
    <li><span>{{name}}</span> <span>{{score}}</span></li>
    {{/each}}
  </ol>
  {{/if}}
</div>
