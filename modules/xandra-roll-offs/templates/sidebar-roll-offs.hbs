<div class="xandra-roll-offs-sidebar">
  <section class="xro-sidebar-content">
    {{#if isActive}}
    <div class="xro-section">
      <h3>{{localize 'XANDRA_ROLL_OFFS.Labels.CurrentRound'}}</h3>
      <p class="xro-current-round">{{roundLabel}}</p>
      <div class="xro-actions">
        <button type="button" data-action="open-roll-off-window">{{localize 'XANDRA_ROLL_OFFS.Actions.OpenRollOff'}}</button>
      </div>
    </div>

    <div class="xro-section">
      <h3>{{localize 'XANDRA_ROLL_OFFS.Labels.Leaderboard'}}</h3>
      <ul class="xro-leaderboard">
        {{#each leaderboard}}
        <li>
          <span>{{name}}</span>
          <span class="score">{{score}}</span>
        </li>
        {{/each}}
      </ul>
    </div>
    {{else}}
    <div class="xro-section xro-empty">
      <p>{{localize 'XANDRA_ROLL_OFFS.Labels.Waiting'}}</p>
      <div class="xro-actions">
        <button type="button" data-action="open-roll-off-window">{{localize 'XANDRA_ROLL_OFFS.Actions.OpenRollOff'}}</button>
      </div>
    </div>
    {{/if}}
  </section>
</div>
